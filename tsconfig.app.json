{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/integrations/*": ["./integration/*"],
      "@/contexts/AuthContext": ["./integration/auth/AuthContext"],
      "@/pages/AuthCallback": ["./integration/auth/AuthCallback"],
      "@/pages/ResetPassword": ["./integration/auth/ResetPassword"],
      "@/components/ProtectedRoute": ["./integration/auth/ProtectedRoute"],
      "@/components/PaymentModal": ["./payment-gateway/PaymentModal"],
      "@/components/PaywallModal": ["./payment-gateway/PaywallModal"],
      "@/*": [
        "./frontend/*",
        "./backend/*",
        "./integration/*",
        "./payment-gateway/*",
        "./ui-ux/*"
      ]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "types": [
      "vitest/globals"
    ],
    "useDefineForClassFields": true
  },
  "include": [
    "frontend",
    "backend",
    "integration",
    "payment-gateway",
    "ui-ux"
  ]
}