# Environment Variables — Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# ─── Supabase ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# ─── App ────────────────────────────────────────────────────────────────────
# Base URL used by Vite (leave as / for root deployments)
BASE_URL=/

# ─── Payment Gateway (Dummy) ─────────────────────────────────────────────────
# Replace with real Razorpay key when moving to production
VITE_RAZORPAY_KEY_ID=rzp_test_placeholder
